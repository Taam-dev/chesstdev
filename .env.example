# Backend Configuration
PORT=8765
HOST=127.0.0.1

# Stockfish Engine Path (leave blank for auto-detect)
ENGINE_PATH=

# Analysis Defaults
DEFAULT_DEPTH=20
DEFAULT_THREADS=2
DEFAULT_HASH_MB=256
DEFAULT_MULTIPV=3

# Development
NODE_ENV=development
PYTHONUNBUFFERED=1

# Feature Flags
ENABLE_WEBCAM=true
ENABLE_SCREEN_CAPTURE=true